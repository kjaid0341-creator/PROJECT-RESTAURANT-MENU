<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Premium Restaurant Menu Dashboard - Manage food items, stock, pricing and customer ratings.">
    <title>Gusto Bistro - Premium Menu Hub</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Custom Style Sheet -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- EJS Helper Functions -->
    <% 
        function getFoodEmoji(name, category) {
            const term = (name + " " + category).toLowerCase();
            if (term.includes("burger")) return "🍔";
            if (term.includes("pizza")) return "🍕";
            if (term.includes("noodle") || term.includes("pasta") || term.includes("chow")) return "🍝";
            if (term.includes("rice") || term.includes("biryani") || term.includes("pulao")) return "🍛";
            if (term.includes("drink") || term.includes("juice") || term.includes("coke") || term.includes("soda") || term.includes("water") || term.includes("tea") || term.includes("coffee") || term.includes("shake")) return "🍹";
            if (term.includes("cake") || term.includes("pastry") || term.includes("dessert") || term.includes("sweet") || term.includes("ice cream") || term.includes("donut")) return "🍰";
            if (term.includes("salad")) return "🥗";
            if (term.includes("chicken") || term.includes("meat") || term.includes("fish") || term.includes("kebab") || term.includes("wing")) return "🍗";
            if (term.includes("soup")) return "🥣";
            if (term.includes("roll") || term.includes("wrap") || term.includes("taco") || term.includes("burrito")) return "🌯";
            if (term.includes("fry") || term.includes("fries")) return "🍟";
            if (term.includes("sandwich") || term.includes("bread") || term.includes("toast")) return "🥪";
            return "🍽️";
        }

        function renderStars(rating) {
            const num = parseFloat(rating) || 0;
            const fullStars = Math.floor(num);
            const halfStar = (num % 1 >= 0.3 && num % 1 <= 0.7) ? 1 : 0;
            const extraFull = num % 1 > 0.7 ? 1 : 0;
            const totalFull = fullStars + extraFull;
            const emptyStars = Math.max(0, 5 - totalFull - halfStar);
            let starsHtml = "";
            for (let i = 0; i < totalFull; i++) {
                starsHtml += '<i class="fas fa-star text-warning"></i>';
            }
            if (halfStar) {
                starsHtml += '<i class="fas fa-star-half-alt text-warning"></i>';
            }
            for (let i = 0; i < emptyStars; i++) {
                starsHtml += '<i class="far fa-star text-secondary" style="opacity: 0.5;"></i>';
            }
            return starsHtml;
        }
    %>

    <div class="container py-5 fade-in-element">
        
        <!-- Dashboard Header -->
        <header class="dashboard-header glass-container">
            <div class="brand-section">
                <h1>🍽️ Gusto Bistro</h1>
                <p>Menu Manager & Analytics Dashboard</p>
            </div>
            <div>
                <a href="/add" class="btn-action-main">
                    <i class="fas fa-plus-circle"></i> Add Food Item
                </a>
            </div>
        </header>

        <!-- Stats Dashboard -->
        <section class="stats-grid">
            <div class="stat-card stat-primary">
                <div class="stat-icon">
                    <i class="fas fa-utensils"></i>
                </div>
                <div class="stat-details">
                    <h3><%= stats.totalFoods %></h3>
                    <p>Total Items</p>
                </div>
            </div>
            
            <div class="stat-card stat-info">
                <div class="stat-icon">
                    <i class="fas fa-star"></i>
                </div>
                <div class="stat-details">
                    <h3><%= stats.avgRating %></h3>
                    <p>Average Rating</p>
                </div>
            </div>
            
            <div class="stat-card stat-success">
                <div class="stat-icon">
                    <i class="fas fa-wallet"></i>
                </div>
                <div class="stat-details">
                    <h3>₹ <%= stats.totalValue.toLocaleString('en-IN') %></h3>
                    <p>Total Value</p>
                </div>
            </div>
            
            <div class="stat-card stat-danger">
                <div class="stat-icon">
                    <i class="fas fa-triangle-exclamation"></i>
                </div>
                <div class="stat-details">
                    <h3><%= stats.lowStock %></h3>
                    <p>Low Stock Items</p>
                </div>
            </div>
        </section>

        <!-- Toolbar: Search, Filters & View Toggle -->
        <div class="glass-container mb-4">
            <div class="dashboard-toolbar">
                <!-- Search bar linking to search route -->
                <form action="/search" method="GET" class="search-bar-container">
                    <input type="text" name="keyword" class="search-input" placeholder="Search menu item..." required>
                    <i class="fas fa-search"></i>
                </form>

                <div class="toolbar-actions">
                    <!-- Dropdown Sort Filter -->
                    <div class="filter-dropdown">
                        <button class="btn-filter-trigger" id="btnSortDropdown" onclick="toggleSortMenu(event)">
                            <i class="fas fa-sliders"></i> Price Filter <i class="fas fa-chevron-down" style="font-size: 0.75rem;"></i>
                        </button>
                        <div class="filter-dropdown-menu" id="sortMenu">
                            <a href="/?sort=asc" class="filter-dropdown-item">
                                <i class="fas fa-sort-amount-up"></i> Price: Low to High
                            </a>
                            <a href="/?sort=desc" class="filter-dropdown-item">
                                <i class="fas fa-sort-amount-down"></i> Price: High to Low
                            </a>
                            <a href="/" class="filter-dropdown-item">
                                <i class="fas fa-rotate-left"></i> Reset Sorting
                            </a>
                        </div>
                    </div>

                    <!-- Layout Toggle Buttons -->
                    <div class="layout-toggle-group">
                        <button class="layout-toggle-btn active" id="toggleGridBtn" onclick="setViewMode('grid')" title="Grid View">
                            <i class="fas fa-th-large"></i>
                        </button>
                        <button class="layout-toggle-btn" id="toggleTableBtn" onclick="setViewMode('table')" title="Table View">
                            <i class="fas fa-list"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Menu Content Section -->
            <div class="menu-view-container">
                <% if(foods.length === 0){ %>
                    <div class="empty-state py-5">
                        <i class="fas fa-hamburger"></i>
                        <h3>Your Menu is Empty</h3>
                        <p>Get started by adding your first restaurant culinary masterpiece to the dashboard.</p>
                        <a href="/add" class="btn btn-action-main mx-auto">
                            <i class="fas fa-plus"></i> Add First Item
                        </a>
                    </div>
                <% } else { %>
                    <!-- Visual Cards Grid View -->
                    <div class="menu-grid" id="menuGrid">
                        <% foods.forEach(food => { %>
                            <div class="food-card-premium">
                                <!-- Hover Actions -->
                                <div class="card-hover-actions">
                                    <a href="/edit/<%= food._id %>" class="action-circle-btn btn-edit" title="Edit Item">
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                    <form action="/delete/<%= food._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this item?');">
                                        <button type="submit" class="action-circle-btn btn-delete" title="Delete Item">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>

                                <div class="card-visual">
                                    <div class="food-avatar">
                                        <%= getFoodEmoji(food.foodName, food.category) %>
                                    </div>
                                    <span class="badge-cat-pill">
                                        <%= food.category %>
                                    </span>
                                </div>

                                <div class="food-title-section">
                                    <h4 title="<%= food.foodName %>"><%= food.foodName %></h4>
                                    <div class="rating-stars">
                                        <%- renderStars(food.rating) %>
                                        <span class="rating-val">(<%= food.rating.toFixed(1) %>)</span>
                                    </div>
                                </div>

                                <div class="card-metrics-divider"></div>

                                <div class="card-footer-metrics">
                                    <div class="metric-price">
                                        <span class="label">Price</span>
                                        <span class="value">₹<%= food.price %></span>
                                    </div>
                                    <div class="metric-qty">
                                        <span class="label">Stock Qty</span>
                                        <% if(food.quantity <= 0) { %>
                                            <span class="qty-badge out-of-stock">Out of Stock</span>
                                        <% } else if(food.quantity < 5) { %>
                                            <span class="qty-badge low-stock"><%= food.quantity %> Low</span>
                                        <% } else { %>
                                            <span class="qty-badge in-stock"><%= food.quantity %> Available</span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>

                    <!-- Clean Table List View (Hidden by default) -->
                    <div class="table-responsive-premium d-none" id="menuTable">
                        <table class="table-premium">
                            <thead>
                                <tr>
                                    <th>Food Name</th>
                                    <th>Category</th>
                                    <th>Price</th>
                                    <th>Stock Status</th>
                                    <th>Rating</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% foods.forEach(food => { %>
                                    <tr>
                                        <td>
                                            <div class="food-name-cell">
                                                <span class="icon"><%= getFoodEmoji(food.foodName, food.category) %></span>
                                                <span><%= food.foodName %></span>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge-cat-pill"><%= food.category %></span>
                                        </td>
                                        <td>
                                            <strong style="color: #10b981;">₹<%= food.price %></strong>
                                        </td>
                                        <td>
                                            <% if(food.quantity <= 0) { %>
                                                <span class="qty-badge out-of-stock">Out of Stock</span>
                                            <% } else if(food.quantity < 5) { %>
                                                <span class="qty-badge low-stock"><%= food.quantity %> Left</span>
                                            <% } else { %>
                                                <span class="qty-badge in-stock"><%= food.quantity %> In Stock</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <div class="rating-stars">
                                                <%- renderStars(food.rating) %>
                                                <span class="rating-val">(<%= food.rating.toFixed(1) %>)</span>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="table-actions-group">
                                                <a href="/edit/<%= food._id %>" class="btn-table-action edit" title="Edit">
                                                    <i class="fas fa-pencil-alt"></i>
                                                </a>
                                                <form action="/delete/<%= food._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this item?');">
                                                    <button type="submit" class="btn-table-action delete" title="Delete">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>

    </div>

    <!-- Scripts -->
    <script>
        // Set and persistent View Mode (Grid vs Table)
        function setViewMode(mode) {
            const gridEl = document.getElementById("menuGrid");
            const tableEl = document.getElementById("menuTable");
            const gridBtn = document.getElementById("toggleGridBtn");
            const tableBtn = document.getElementById("toggleTableBtn");

            if (!gridEl || !tableEl) return;

            if (mode === "grid") {
                gridEl.classList.remove("d-none");
                tableEl.classList.add("d-none");
                gridBtn.classList.add("active");
                tableBtn.classList.remove("active");
            } else {
                gridEl.classList.add("d-none");
                tableEl.classList.remove("d-none");
                gridBtn.classList.remove("active");
                tableBtn.classList.add("active");
            }

            localStorage.setItem("menuViewMode", mode);
        }

        // Initialize view mode from storage
        window.addEventListener("DOMContentLoaded", () => {
            const savedMode = localStorage.getItem("menuViewMode") || "grid";
            setViewMode(savedMode);
        });

        // Dropdown toggle
        function toggleSortMenu(e) {
            e.stopPropagation();
            const menu = document.getElementById("sortMenu");
            const trigger = document.getElementById("btnSortDropdown");
            menu.classList.toggle("show");
            trigger.classList.toggle("active");
        }

        // Close dropdown when clicking outside
        window.addEventListener("click", () => {
            const menu = document.getElementById("sortMenu");
            const trigger = document.getElementById("btnSortDropdown");
            if (menu && menu.classList.contains("show")) {
                menu.classList.remove("show");
                trigger.classList.remove("active");
            }
        });

        // Delete confirm dialog
        function confirmDelete(foodName) {
            return confirm(`Are you sure you want to delete "${foodName}" from the menu?`);
        }
    </script>
</body>
</html>