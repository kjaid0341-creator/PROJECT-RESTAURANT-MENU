<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Menu - Gusto Bistro</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Custom Style Sheet -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- EJS Helper Functions -->
    <% 
        function getFoodEmoji(name, category) {
            const term = (name + " " + category).toLowerCase();
            if (term.includes("burger")) return "🍔";
            if (term.includes("pizza")) return "🍕";
            if (term.includes("noodle") || term.includes("pasta") || term.includes("chow")) return "🍝";
            if (term.includes("rice") || term.includes("biryani") || term.includes("pulao")) return "🍛";
            if (term.includes("drink") || term.includes("juice") || term.includes("coke") || term.includes("soda") || term.includes("water") || term.includes("tea") || term.includes("coffee") || term.includes("shake")) return "🍹";
            if (term.includes("cake") || term.includes("pastry") || term.includes("dessert") || term.includes("sweet") || term.includes("ice cream") || term.includes("donut")) return "🍰";
            if (term.includes("salad")) return "🥗";
            if (term.includes("chicken") || term.includes("meat") || term.includes("fish") || term.includes("kebab") || term.includes("wing")) return "🍗";
            if (term.includes("soup")) return "🥣";
            if (term.includes("roll") || term.includes("wrap") || term.includes("taco") || term.includes("burrito")) return "🌯";
            if (term.includes("fry") || term.includes("fries")) return "🍟";
            if (term.includes("sandwich") || term.includes("bread") || term.includes("toast")) return "🥪";
            return "🍽️";
        }

        function renderStars(rating) {
            const num = parseFloat(rating) || 0;
            const fullStars = Math.floor(num);
            const halfStar = (num % 1 >= 0.3 && num % 1 <= 0.7) ? 1 : 0;
            const extraFull = num % 1 > 0.7 ? 1 : 0;
            const totalFull = fullStars + extraFull;
            const emptyStars = Math.max(0, 5 - totalFull - halfStar);
            let starsHtml = "";
            for (let i = 0; i < totalFull; i++) {
                starsHtml += '<i class="fas fa-star text-warning"></i>';
            }
            if (halfStar) {
                starsHtml += '<i class="fas fa-star-half-alt text-warning"></i>';
            }
            for (let i = 0; i < emptyStars; i++) {
                starsHtml += '<i class="far fa-star text-secondary" style="opacity: 0.5;"></i>';
            }
            return starsHtml;
        }
    %>

    <div class="container py-5 fade-in-element">

        <div class="glass-container mb-4">
            
            <div class="form-header text-center mb-5">
                <div class="icon-container" style="background: rgba(245, 158, 11, 0.1); border-color: rgba(245, 158, 11, 0.2); color: var(--primary); width: 60px; height: 60px; border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 12px auto;">
                    <i class="fas fa-search"></i>
                </div>
                <h2 style="font-size: 2rem;">Search Menu</h2>
                <p>Search and filter food items dynamically</p>
            </div>

            <!-- Search form -->
            <form action="/search" method="GET" class="d-flex justify-content-center mb-5">
                <div class="search-bar-container" style="max-width: 600px; width: 100%;">
                    <input 
                        type="text" 
                        name="keyword" 
                        class="search-input" 
                        placeholder="Type food name (e.g. Pizza, Burger...)" 
                        value="<%= typeof keyword !== 'undefined' ? keyword : '' %>"
                        required
                        style="padding-right: 120px;"
                    >
                    <i class="fas fa-search"></i>
                    <button type="submit" class="btn-action-main" style="position: absolute; right: 4px; top: 4px; bottom: 4px; padding: 0 24px; font-size: 0.85rem; height: calc(100% - 8px); box-shadow: none;">
                        Search
                    </button>
                </div>
            </form>

            <div class="menu-view-container">
                <% if(foods && foods.length > 0) { %>
                    <h5 class="mb-4 text-muted"><i class="fas fa-circle-dot text-primary" style="font-size: 0.7rem; vertical-align: middle;"></i> Found <%= foods.length %> item(s) matching your request:</h5>
                    
                    <div class="menu-grid">
                        <% foods.forEach(food => { %>
                            <div class="food-card-premium">
                                <!-- Hover Actions -->
                                <div class="card-hover-actions">
                                    <a href="/edit/<%= food._id %>" class="action-circle-btn btn-edit" title="Edit Item">
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                    <form action="/delete/<%= food._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this item?');">
                                        <button type="submit" class="action-circle-btn btn-delete" title="Delete Item">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>

                                <div class="card-visual">
                                    <div class="food-avatar">
                                        <%= getFoodEmoji(food.foodName, food.category) %>
                                    </div>
                                    <span class="badge-cat-pill">
                                        <%= food.category %>
                                    </span>
                                </div>

                                <div class="food-title-section">
                                    <h4 title="<%= food.foodName %>"><%= food.foodName %></h4>
                                    <div class="rating-stars">
                                        <%- renderStars(food.rating) %>
                                        <span class="rating-val">(<%= food.rating.toFixed(1) %>)</span>
                                    </div>
                                </div>

                                <div class="card-metrics-divider"></div>

                                <div class="card-footer-metrics">
                                    <div class="metric-price">
                                        <span class="label">Price</span>
                                        <span class="value">₹<%= food.price %></span>
                                    </div>
                                    <div class="metric-qty">
                                        <span class="label">Stock Qty</span>
                                        <% if(food.quantity <= 0) { %>
                                            <span class="qty-badge out-of-stock">Out of Stock</span>
                                        <% } else if(food.quantity < 5) { %>
                                            <span class="qty-badge low-stock"><%= food.quantity %> Low</span>
                                        <% } else { %>
                                            <span class="qty-badge in-stock"><%= food.quantity %> Available</span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="empty-state py-5">
                        <i class="fas fa-circle-question"></i>
                        <h3>No Results Found</h3>
                        <p>We couldn't find any menu items matching "<%= keyword %>". Try checking spelling or search for something else.</p>
                        <a href="/" class="btn btn-action-secondary mx-auto">
                            <i class="fas fa-arrow-rotate-left"></i> View All Menu
                        </a>
                    </div>
                <% } %>
            </div>

            <!-- Back to Home -->
            <div class="text-center mt-5">
                <a href="/" class="back-link d-inline-flex">
                    <i class="fas fa-arrow-left-long"></i> Back to Dashboard
                </a>
            </div>

        </div>

    </div>

    <!-- Scripts -->
    <script>
        // Delete confirm dialog
        function confirmDelete(foodName) {
            return confirm(`Are you sure you want to delete "${foodName}" from the menu?`);
        }
    </script>
</body>
</html>