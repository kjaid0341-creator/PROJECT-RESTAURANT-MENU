<!-- <!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Sort Foods</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    min-height:100vh;

    background:linear-gradient(
        -45deg,
        #0f2027,
        #203a43,
        #2c5364,
        #1e3c72
    );

    background-size:400% 400%;
    animation:bgMove 12s ease infinite;
}

@keyframes bgMove{
    0%{background-position:0% 50%;}
    50%{background-position:100% 50%;}
    100%{background-position:0% 50%;}
}

.container-box{
    padding:40px;
}

.glass-card{
    background:rgba(255,255,255,0.08);
    backdrop-filter:blur(15px);
    border-radius:30px;
    padding:30px;
    box-shadow:0 15px 35px rgba(0,0,0,0.4);
    color:white;
}

.header{
    text-align:center;
    margin-bottom:30px;
}

.header h1{
    font-size:3rem;
    font-weight:700;
}

.header p{
    opacity:0.8;
}

.sort-buttons{
    text-align:center;
    margin-bottom:20px;
}

.filter-btn{
    background:linear-gradient(
        45deg,
        #8e2de2,
        #4a00e0
    );

    color:white;
    border:none;
    padding:14px 35px;
    border-radius:50px;
    font-size:18px;
    font-weight:600;
    cursor:pointer;
    transition:.4s;
}

.filter-btn:hover{
    transform:translateY(-5px);
    box-shadow:0 10px 25px rgba(142,45,226,.5);
}

.home-btn{
    display:inline-block;
    margin-left:10px;

    background:linear-gradient(
        45deg,
        #2196f3,
        #00b0ff
    );

    color:white;
    text-decoration:none;
    padding:14px 35px;
    border-radius:50px;
    font-weight:600;
    transition:.4s;
}

.home-btn:hover{
    transform:translateY(-5px);
}

.filter-panel{
    display:none;
    text-align:center;
    margin-bottom:30px;
}

.filter-option{
    display:inline-block;
    margin:10px;
    padding:12px 25px;
    border-radius:15px;
    text-decoration:none;
    color:white;
    background:rgba(255,255,255,.15);
    backdrop-filter:blur(10px);
    transition:.3s;
}

.filter-option:hover{
    transform:translateY(-3px);
    background:rgba(255,255,255,.25);
}

.food-grid{
    display:grid;
    grid-template-columns:
    repeat(auto-fit,minmax(280px,1fr));
    gap:25px;
}

.food-card{
    background:rgba(255,255,255,0.08);

    backdrop-filter:blur(12px);

    border-radius:20px;

    padding:20px;

    color:white;

    transition:0.4s;

    box-shadow:
    0 10px 20px rgba(0,0,0,0.3);
}

.food-card:hover{
    transform:
    translateY(-10px)
    rotateX(5deg);

    box-shadow:
    0 20px 40px rgba(0,0,0,0.4);
}

.food-name{
    font-size:1.4rem;
    font-weight:700;
    margin-bottom:10px;
}

.category{
    display:inline-block;
    background:#2196f3;
    padding:6px 12px;
    border-radius:20px;
    margin-bottom:15px;
}

.price{
    color:#00ff95;
    font-size:1.4rem;
    font-weight:700;
}

.quantity{
    margin-top:10px;
}

.rating{
    color:gold;
    margin-top:10px;
    font-weight:600;
}

.empty{
    text-align:center;
    color:white;
    margin-top:50px;
}

</style>
</head>

<body>

<div class="container container-box">

    <div class="glass-card">

        <div class="header">
            <h1>🍽️ Menu Filters</h1>
            <p>Sort and manage restaurant food items</p>
        </div>

        <div class="sort-buttons">

            <button class="filter-btn" onclick="toggleFilters()">
                ⚙️ Filters
            </button>

            <a href="/" class="home-btn">
                🏠 Dashboard
            </a>

        </div>

        <div id="filterPanel" class="filter-panel">

            <a href="/sort/asc" class="filter-option">
                ⬆ Price: Low → High
            </a>

            <a href="/sort/desc" class="filter-option">
                ⬇ Price: High → Low
            </a>

        </div>

        <% if(foods.length === 0){ %>

            <div class="empty">
                <h3>No Food Items Found</h3>
            </div>

        <% } else { %>

        <div class="food-grid">

            <% foods.forEach(food => { %>

            <div class="food-card">

                <div class="food-name">
                    🍔 <%= food.foodName %>
                </div>

                <div class="category">
                    <%= food.category %>
                </div>

                <div class="price">
                    ₹ <%= food.price %>
                </div>

                <div class="quantity">
                    📦 Quantity: <%= food.quantity %>
                </div>

                <div class="rating">
                    ⭐ Rating: <%= food.rating %>
                </div>

            </div>

            <% }) %>

        </div>

        <% } %>

    </div>

</div>

<script>
function toggleFilters(){
    const panel = document.getElementById("filterPanel");

    if(panel.style.display === "block"){
        panel.style.display = "none";
    }else{
        panel.style.display = "block";
    }
}
</script>

</body>
</html> -->