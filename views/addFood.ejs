<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Menu Item - Gusto Bistro</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Custom Style Sheet -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <div class="container py-5 d-flex justify-content-center align-items-center" style="min-height: 90vh;">
        
        <div class="glass-container glass-form-card fade-in-element">
            
            <div class="form-header">
                <div class="icon-container">
                    <i class="fas fa-hamburger"></i>
                </div>
                <h2>Add Food Item</h2>
                <p>Create and append a new dish to your restaurant menu dashboard</p>
            </div>

            <form action="/add" method="POST" class="premium-form">
                
                <!-- Food Name -->
                <div class="form-group-custom">
                    <label for="foodName">Food Name</label>
                    <div class="input-icon-wrapper">
                        <input 
                            type="text" 
                            id="foodName"
                            name="foodName" 
                            class="input-premium" 
                            placeholder="e.g. Double Cheese Pizza"
                            required
                        >
                        <i class="fas fa-utensils"></i>
                    </div>
                </div>

                <!-- Category -->
                <div class="form-group-custom">
                    <label for="category">Category</label>
                    <div class="input-icon-wrapper">
                        <input 
                            type="text" 
                            id="category"
                            name="category" 
                            class="input-premium" 
                            placeholder="e.g. Pizza, Burger, Desserts, Drinks"
                            required
                        >
                        <i class="fas fa-tag"></i>
                    </div>
                </div>

                <div class="row">
                    <!-- Price -->
                    <div class="col-md-6 form-group-custom">
                        <label for="price">Price (₹)</label>
                        <div class="input-icon-wrapper">
                            <input 
                                type="number" 
                                id="price"
                                name="price" 
                                class="input-premium" 
                                placeholder="Price in ₹"
                                min="0"
                                required
                            >
                            <i class="fas fa-wallet"></i>
                        </div>
                    </div>

                    <!-- Quantity -->
                    <div class="col-md-6 form-group-custom">
                        <label for="quantity">Quantity (Stock)</label>
                        <div class="input-icon-wrapper">
                            <input 
                                type="number" 
                                id="quantity"
                                name="quantity" 
                                class="input-premium" 
                                placeholder="Units in stock"
                                min="0"
                                required
                            >
                            <i class="fas fa-cubes"></i>
                        </div>
                    </div>
                </div>

                <!-- Rating -->
                <div class="form-group-custom">
                    <label for="rating">Rating (1.0 - 5.0)</label>
                    <div class="input-icon-wrapper">
                        <input 
                            type="number" 
                            id="rating"
                            step="0.1" 
                            min="1.0" 
                            max="5.0" 
                            name="rating" 
                            class="input-premium" 
                            placeholder="Initial customer rating (e.g. 4.5)"
                            required
                        >
                        <i class="fas fa-star"></i>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn-action-main btn-form-submit">
                    <i class="fas fa-plus-circle"></i> Add Food Item
                </button>

            </form>

            <!-- Back Link -->
            <a href="/" class="back-link">
                <i class="fas fa-arrow-left-long"></i> Back to Dashboard
            </a>

        </div>

    </div>

</body>
</html>