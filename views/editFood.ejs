<!DOCTYPE html>
<html>
<head>
    <title>Edit Food</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<div class="container mt-5">

    <div class="card shadow p-4">

        <h2 class="text-center text-primary">
            Edit Food
        </h2>

        <form action="/update/<%= food._id %>" method="POST">

            <input
                type="text"
                name="foodName"
                value="<%= food.foodName %>"
                class="form-control mb-3">

            <input
                type="text"
                name="category"
                value="<%= food.category %>"
                class="form-control mb-3">

            <input
                type="number"
                name="price"
                value="<%= food.price %>"
                class="form-control mb-3">

            <input
                type="number"
                name="quantity"
                value="<%= food.quantity %>"
                class="form-control mb-3">

            <input
                type="number"
                step="0.1"
                name="rating"
                value="<%= food.rating %>"
                class="form-control mb-3">

            <button class="btn btn-primary w-100">
                Update Food
            </button>

        </form>

    </div>

</div>

</body>
</html>