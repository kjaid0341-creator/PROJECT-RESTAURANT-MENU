<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Add Food</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;

    background:linear-gradient(
        -45deg,
        #1e3c72,
        #2a5298,
        #6a11cb,
        #2575fc
    );

    background-size:400% 400%;
    animation:bgAnimation 10s ease infinite;
}

@keyframes bgAnimation{
    0%{background-position:0% 50%;}
    50%{background-position:100% 50%;}
    100%{background-position:0% 50%;}
}

.form-card{
    width:700px;
    padding:40px;

    background:rgba(255,255,255,0.08);

    backdrop-filter:blur(18px);

    border-radius:30px;

    box-shadow:
    0 15px 35px rgba(0,0,0,0.4),
    inset 0 1px 1px rgba(255,255,255,0.2);

    color:white;

    animation:floatCard 4s ease-in-out infinite;
}

@keyframes floatCard{
    0%{
        transform:translateY(0px);
    }
    50%{
        transform:translateY(-10px);
    }
    100%{
        transform:translateY(0px);
    }
}

.title{
    text-align:center;
    margin-bottom:30px;
}

.title h1{
    font-size:2.5rem;
    font-weight:700;
}

.title p{
    opacity:0.8;
}

.form-control{
    background:rgba(255,255,255,0.15);
    border:none;
    color:white;
    padding:14px;
    border-radius:15px;
}

.form-control:focus{
    background:rgba(255,255,255,0.2);
    color:white;
    box-shadow:0 0 15px rgba(255,255,255,0.3);
}

.form-control::placeholder{
    color:rgba(255,255,255,0.7);
}

label{
    margin-bottom:8px;
    font-weight:500;
}

.submit-btn{
    width:100%;
    padding:15px;

    border:none;

    border-radius:50px;

    background:linear-gradient(
        45deg,
        #00c853,
        #64dd17
    );

    color:white;

    font-size:18px;
    font-weight:600;

    transition:0.4s;
}

.submit-btn:hover{
    transform:translateY(-5px);
    box-shadow:
    0 10px 25px rgba(0,255,0,0.4);
}

.back-btn{
    display:block;
    text-align:center;
    margin-top:20px;
    color:white;
    text-decoration:none;
}

.back-btn:hover{
    color:#ddd;
}

.food-icon{
    font-size:60px;
    margin-bottom:15px;
}

</style>

</head>

<body>

<div class="form-card">

    <div class="title">

        <div class="food-icon">
            🍔
        </div>

        <h1>Add Food Item</h1>

        <p>
            Create and manage your restaurant menu
        </p>

    </div>

    <form action="/add" method="POST">

        <div class="mb-3">

            <label>Food Name</label>

            <input
                type="text"
                name="foodName"
                class="form-control"
                placeholder="Enter Food Name"
                required
            >

        </div>

        <div class="mb-3">

            <label>Category</label>

            <input
                type="text"
                name="category"
                class="form-control"
                placeholder="Enter Category"
                required
            >

        </div>

        <div class="row">

            <div class="col-md-6 mb-3">

                <label>Price</label>

                <input
                    type="number"
                    name="price"
                    class="form-control"
                    placeholder="Enter Price"
                    required
                >

            </div>

            <div class="col-md-6 mb-3">

                <label>Quantity</label>

                <input
                    type="number"
                    name="quantity"
                    class="form-control"
                    placeholder="Enter Quantity"
                    required
                >

            </div>

        </div>

        <div class="mb-4">

            <label>Rating</label>

            <input
                type="number"
                step="0.1"
                min="1"
                max="5"
                name="rating"
                class="form-control"
                placeholder="Enter Rating (1-5)"
                required
            >

        </div>

        <button type="submit" class="submit-btn">
            ➕ Add Food Item
        </button>

    </form>

    <a href="/" class="back-btn">
        ⬅ Back to Dashboard
    </a>

</div>

</body>
</html>